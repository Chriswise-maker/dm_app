{
  "name": "Help — grant advantage to an ally",
  "description": "Exercises HELP action toward Mira (ally). Watch for parser mapping ally name → entity. sessionId 25, characterId 26.",
  "sessionId": 25,
  "characterId": 26,
  "steps": [
    {
      "message": "Orc scouts howl from the ridge — I draw my weapon and engage!",
      "expect": {
        "minLength": 25,
        "combatTriggered": true,
        "notContains": ["error", "undefined"]
      },
      "expectCombat": {
        "entityCount": { "min": 2 }
      },
      "settleTimeoutMs": 10000
    },
    {
      "message": "18",
      "delayMs": 1000
    },
    {
      "message": "8",
      "delayMs": 500,
      "expectCombat": {
        "phase": "ACTIVE",
        "round": 1
      },
      "settleTimeoutMs": 10000
    },
    {
      "message": "I use the Help action—I feint and shout to draw the orc's eyes so Mira gets a clean shot!",
      "delayMs": 3000,
      "expect": {
        "notContains": ["error", "undefined", "no valid target"]
      },
      "settleTimeoutMs": 12000
    },
    {
      "message": "I end my turn.",
      "delayMs": 2000,
      "expect": {
        "minLength": 8,
        "notContains": ["error", "undefined"]
      },
      "expectCombat": {
        "hp": {
          "Silas Gravemourn": { "min": 0, "max": 28 },
          "Mira Ashenthorn": { "min": 0, "max": 11 }
        }
      },
      "settleTimeoutMs": 22000
    }
  ]
