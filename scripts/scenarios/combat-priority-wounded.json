{
  "name": "Priority target — finish the wounded foe",
  "description": "Natural-language targeting ('the bloodied one', 'whoever is hurt worst'). Parser should still map to an enemy entity. sessionId 25.",
  "sessionId": 25,
  "characterId": 26,
  "steps": [
    {
      "message": "Two duellists circle us — one is already wounded. I draw my weapon and fight!",
      "expect": {
        "minLength": 30,
        "combatTriggered": true,
        "notContains": ["error", "undefined"]
      },
      "expectCombat": {
        "entityCount": { "min": 3 }
      },
      "settleTimeoutMs": 12000
    },
    {
      "message": "16",
      "delayMs": 1000
    },
    {
      "message": "9",
      "delayMs": 500,
      "expectCombat": {
        "phase": "ACTIVE",
        "round": 1
      },
      "settleTimeoutMs": 12000
    },
    {
      "message": "I focus on the wounded duelist—I thrust my quarterstaff at the bleeding one before they recover!",
      "delayMs": 4000,
      "expect": {
        "notContains": ["error", "undefined", "no target"]
      },
      "rolls": [
        { "rollType": "attack", "rawDieValue": 15 },
        { "rollType": "damage", "rawDieValue": 6 }
      ],
      "settleTimeoutMs": 14000
    },
    {
      "message": "I end my turn.",
      "delayMs": 2000,
      "expect": {
        "minLength": 8,
        "notContains": ["error", "undefined"]
      },
      "expectCombat": {
        "entityCount": { "min": 2 }
      },
      "settleTimeoutMs": 22000
    }
  ]
}
