{
  "name": "Critical hit (nat 20) and fumble (nat 1) test",
  "description": "Round 1: Fire Bolt with nat 20 crit — double damage dice (4d10, range 4-40). End turn, wait. Round 2: attack with nat 1 fumble — auto miss, no damage roll needed.",
  "sessionId": 25,
  "characterId": 26,
  "steps": [
    {
      "message": "Undead shamble toward us — I raise my staff and attack them!",
      "expect": {
        "minLength": 20,
        "combatTriggered": true
      },
      "expectCombat": {
        "entityCount": { "min": 2 }
      },
      "settleTimeoutMs": 8000
    },
    {
      "message": "17",
      "delayMs": 1000
    },
    {
      "message": "11",
      "delayMs": 500,
      "expectCombat": {
        "phase": "ACTIVE",
        "round": 1
      },
      "settleTimeoutMs": 10000
    },
    {
      "message": "I cast Fire Bolt at the nearest zombie!",
      "delayMs": 3000,
      "expect": {
        "notContains": ["error", "undefined"]
      },
      "rolls": [
        { "rollType": "attack", "rawDieValue": 20 },
        { "rollType": "damage", "rawDieValue": 28 }
      ],
      "settleTimeoutMs": 10000
    },
    {
      "message": "I end my turn.",
      "delayMs": 2000,
      "expect": {
        "minLength": 10,
        "notContains": ["despair", "exhaustion", "error", "undefined"]
      },
      "expectCombat": {
        "hp": {
          "Silas Gravemourn": { "min": 0, "max": 28 },
          "Mira Ashenthorn": { "min": 0, "max": 11 }
        }
      },
      "settleTimeoutMs": 20000
    },
    {
      "message": "I swing my quarterstaff at the zombie!",
      "delayMs": 8000,
      "expect": {
        "notContains": ["error", "undefined"]
      },
      "rolls": [
        { "rollType": "attack", "rawDieValue": 1 }
      ],
      "settleTimeoutMs": 10000
    },
    {
      "message": "I end my turn.",
      "delayMs": 2000,
      "expect": {
        "minLength": 10,
        "notContains": ["error", "undefined"]
      },
      "settleTimeoutMs": 20000
    }
  ]
}
