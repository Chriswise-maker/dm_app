        "round": 1
      },
      "settleTimeoutMs": 10000
    },
    {
      "message": "I swing my quarterstaff wildly at the beast—I'm nervous!",
      "delayMs": 3000,
      "expect": {
        "notContains": ["error", "undefined"]
      },
      "rolls": [{ "rollType": "attack", "rawDieValue": 3 }],
      "expectCombat": {
        "phase": "ACTIVE"
      },
      "settleTimeoutMs": 12000
    },
    {
      "message": "I end my turn.",
      "delayMs": 2000,
      "expect": {
