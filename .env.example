# D&D Dungeon Master App - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Database (PostgreSQL)
# Get a free database at https://neon.tech
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT Secret for authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ============================================
# LLM PROVIDERS (at least one required)
# ============================================

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude - https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini (has free tier) - https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# App branding
VITE_APP_TITLE=D&D Dungeon Master Chat
VITE_APP_LOGO=/favicon.ico

# Server port (default: 3000)
PORT=3000

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ============================================
# OAUTH (Optional - for multi-user support)
# ============================================
# If not configured, app runs in single-user mode

OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000
OWNER_OPEN_ID=local-user
OWNER_NAME=Local User
